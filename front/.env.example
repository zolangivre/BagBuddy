# These defaults work out of the box against the local backend started from
# ../back (see ../back/README.md) — copy this file to .env and you're set.

# Backend API (api-gateway)
EXPO_PUBLIC_API_URL=http://localhost:8080

# Keycloak (auth) — realm/client are auto-created by the backend's docker compose
EXPO_PUBLIC_KEYCLOAK_URL=http://localhost:8000/realms/bagbuddy
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=bagbuddy-mobile
EXPO_PUBLIC_KEYCLOAK_ACCOUNT_CONSOLE=http://localhost:8000/realms/bagbuddy/account

# Stripe (leave empty — stripe-service is disabled locally until real test keys are set, see ../back/README.md)
EXPO_PUBLIC_STRIPE_API_URL=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
