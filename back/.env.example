# Local dev credentials for docker-compose.dev.yml — copy to .env and fill in.
# These are only used by local Postgres/Keycloak containers, never sent anywhere external.

# KEYCLOAK
# ======================================= #
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=
# ======================================= #

# TRIP_SERVICE_DB
# ======================================= #
TRIP_SERVICE_DB=tripservice
TRIP_SERVICE_USER=tripservice
TRIP_SERVICE_PASSWORD=
TRIP_SERVICE_DB_PORT=5440
# ======================================= #

# TRANSACTION_SERVICE_DB
# ======================================= #
TRANSACTION_SERVICE_DB=transactionservice
TRANSACTION_SERVICE_USER=transactionservice
TRANSACTION_SERVICE_PASSWORD=
TRANSACTION_SERVICE_DB_PORT=5441
# ======================================= #

# REVIEW_SERVICE_DB
# ======================================= #
REVIEW_SERVICE_DB=reviewservice
REVIEW_SERVICE_USER=reviewservice
REVIEW_SERVICE_PASSWORD=
REVIEW_SERVICE_DB_PORT=5442
# ======================================= #

# STRIPE (only needed if you re-enable stripe-service in docker-compose.dev.yml)
# ======================================= #
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# ======================================= #
