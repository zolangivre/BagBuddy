type Review {
    review_id: ID!
    author_id: Int!
    target_id: Int!
    rating: Int!
    comment: String
    review_date: String
}

type Query {
    reviews: [Review]
    review(review_id: ID!): Review
    reviewsByAuthor(author_id: Int!): [Review]
    reviewsByTarget(target_id: Int!): [Review]
}

type Mutation {
    createReview(author_id: Int!, target_id: Int!, rating: Int!, comment: String): Review
}
